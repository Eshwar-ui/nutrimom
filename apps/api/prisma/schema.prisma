// Prisma schema for The Nurture Moms — a preloved baby & maternity marketplace.
// Money is stored as integer paise everywhere — never floats.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER // can buy and sell
  ADMIN
}

enum Condition {
  NEW // new with tags / never used
  LIKE_NEW
  GOOD
  FAIR
}

enum DeliveryOption {
  PICKUP
  DELIVERY
  BOTH
}

enum ListingStatus {
  PENDING // awaiting admin approval
  APPROVED // live and buyable
  REJECTED
  RESERVED // temporarily held for a buyer
  SOLD
}

enum OrderStatus {
  PENDING // created, awaiting payment
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD // RETIRED — retained only so historical orders stay valid; not selectable
  ONLINE // Online gateway (Razorpay/…) — the only method for new orders
}

enum SellerPaymentType {
  REGISTRATION // one-time ₹100 account activation
  MEMBERSHIP // a prepaid plan purchase
}

enum SellerPaymentStatus {
  PENDING // gateway order created, awaiting payment
  PAID // verified/settled
  FAILED
}

enum MembershipPlan {
  MONTHLY // 30 days
  QUARTERLY // 90 days
  HALF_YEARLY // 180 days
  YEARLY // 365 days
}

enum ShipmentStatus {
  PENDING // order paid, seller has not generated a label yet
  LABEL_GENERATED // label created, ready to print + hand over
  SHIPPED // handed to the courier
  DELIVERED
}

enum NotificationType {
  LISTING_APPROVED
  LISTING_REJECTED
  ITEM_SOLD // to the seller
  ORDER_PLACED // to the admin
  ORDER_CANCELLED // to the seller
}

model User {
  id                            String         @id @default(cuid())
  email                         String         @unique
  passwordHash                  String
  name                          String
  role                          Role           @default(CUSTOMER)
  // Seller profile
  whatsappNumber                String?
  city                          String?
  bio                           String?
  isSellerVerified              Boolean        @default(false)
  sellerVerificationRequestedAt DateTime?
  // Monetization: ₹100 one-time registration fee gate (paid online). Must be
  // set before a seller can buy a membership plan or create listings.
  registrationPaidAt            DateTime?
  listings                      Listing[]
  orders                        Order[]
  wishlist                      WishlistItem[]
  notifications                 Notification[]
  reviewsWritten                Review[]       @relation("ReviewsWritten")
  reviewsReceived               Review[]       @relation("ReviewsReceived")
  sellerPayments                SellerPayment[]
  memberships                   SellerMembership[]
  createdAt                     DateTime       @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  listings Listing[]
}

model Listing {
  id                   String         @id @default(cuid())
  title                String
  description          String
  seller               User           @relation(fields: [sellerId], references: [id])
  sellerId             String
  category             Category       @relation(fields: [categoryId], references: [id])
  categoryId           String
  condition            Condition
  originalPriceInPaise Int? // what the seller paid new
  sellingPriceInPaise  Int
  purchaseDate         DateTime?
  usageDuration        String? // free text, e.g. "6 months"
  reasonForSelling     String?
  city                 String
  deliveryOption       DeliveryOption @default(PICKUP)
  images               String[] // up to 10, enforced in app
  status               ListingStatus  @default(PENDING)
  isFeatured           Boolean        @default(false)
  // Optional reservation hold
  reservedById         String?
  reservedUntil        DateTime?
  orderItems           OrderItem[]
  wishlistedBy         WishlistItem[]
  reviews              Review[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

model WishlistItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model Order {
  id                String      @id @default(cuid())
  buyer             User        @relation(fields: [buyerId], references: [id])
  buyerId           String
  status            OrderStatus   @default(PENDING)
  paymentMethod     PaymentMethod @default(ONLINE)
  totalInPaise      Int
  shippingAddress   Json
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  items             OrderItem[]
  reviews           Review[]
  shipments         Shipment[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id               String  @id @default(cuid())
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  // Restrict: a listing that has been ordered can never be hard-deleted.
  listing          Listing @relation(fields: [listingId], references: [id], onDelete: Restrict)
  listingId        String
  listingTitle     String // snapshot at purchase
  sellerId         String // snapshot — who gets paid / notified
  unitPriceInPaise Int // snapshot (selling price)
  image            String?

  @@index([orderId])
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  message   String
  listingId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

// A buyer rates the seller of one purchased listing, once per order line.
model Review {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId  String
  reviewer   User     @relation("ReviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId String
  seller     User     @relation("ReviewsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId   String
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([orderId, listingId])
  @@index([sellerId])
  @@index([listingId])
}

// A seller's payment for registration or a membership plan (online only). The
// gateway ids mirror Order's; on settle a MEMBERSHIP payment creates/extends a
// SellerMembership window.
model SellerPayment {
  id               String              @id @default(cuid())
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  type             SellerPaymentType
  plan             MembershipPlan? // set only when type = MEMBERSHIP
  amountInPaise    Int // authoritative amount from the server
  status           SellerPaymentStatus @default(PENDING)
  gatewayOrderId   String?             @unique
  gatewayPaymentId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([userId])
}

// A prepaid access window. A seller may list only while some window has
// expiresAt in the future. Buying while active stacks onto the current expiry.
model SellerMembership {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  plan      MembershipPlan
  startsAt  DateTime       @default(now())
  expiresAt DateTime
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// One seller's shippable portion of an order (an order may span sellers). The
// seller generates a marketplace label, prints it, and marks it shipped. For a
// courier provider (Shiprocket/…) labelUrl + trackingId hold the AWB; for the
// built-in manual provider the label is rendered on demand and labelGeneratedAt
// records that it was produced.
model Shipment {
  id               String         @id @default(cuid())
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  sellerId         String
  status           ShipmentStatus @default(PENDING)
  courier          String?
  trackingId       String?
  labelUrl         String?
  labelGeneratedAt DateTime?
  shippedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([orderId, sellerId])
  @@index([sellerId])
}
