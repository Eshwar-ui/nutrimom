# Copy the relevant blocks into apps/api/.env and apps/web/.env.local

# ---- apps/api/.env ----
# Local PostgreSQL:
DATABASE_URL="postgresql://nutrimom:nutrimom@localhost:5432/nutrimom?schema=public"
DIRECT_URL="postgresql://nutrimom:nutrimom@localhost:5432/nutrimom?schema=public"
# Supabase/hosted PostgreSQL: use the pooled URL for DATABASE_URL and the
# direct connection URL for DIRECT_URL. URL-encode special password characters.
PORT=4001
# Comma-separated allowlist of front-end origins (no trailing slash).
CORS_ORIGIN="http://localhost:4000"

# Auth — generate strong random values in production (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Payment gateway. Online payment is the only method (COD is retired).
# Only 'razorpay' is implemented today; add an adapter to support more.
PAYMENT_PROVIDER="razorpay"
# Shipping label provider (only 'manual' implemented — printable label, no vendor).
SHIPPING_PROVIDER="manual"
# Razorpay (use TEST keys from https://dashboard.razorpay.com in dev)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Supabase Storage — holds seller-uploaded listing photos.
# Project → Settings → API: use the Project URL and the SERVICE ROLE key
# (server-only; never expose it to the browser). Create a PUBLIC bucket whose
# name matches SUPABASE_STORAGE_BUCKET.
SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service-role-key..."
SUPABASE_STORAGE_BUCKET="listing-images"

# Seeded admin account
ADMIN_EMAIL="admin@nutrimom.local"
ADMIN_PASSWORD="admin12345"

# ---- apps/web/.env.local ----
NEXT_PUBLIC_API_URL="http://localhost:4001"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# Public site origin, no trailing slash — used for sitemap.xml
NEXT_PUBLIC_SITE_URL="http://localhost:4000"
